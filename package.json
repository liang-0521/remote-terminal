{
  "name": "remote-terminal",
  "version": "0.1.0",
  "description": "Windows client for SSH terminals, SFTP transfers, and Linux performance monitoring.",
  "author": "Liang",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "node scripts/dev-electron.mjs",
    "build:icon": "node scripts/build-icon.mjs",
    "prebuild": "node scripts/build-preload.mjs",
    "build": "vite build",
    "desktop": "npm run build && electron .",
    "package:win": "npm run build && electron-builder --win nsis --x64 --publish never && node scripts/package-win.mjs",
    "preview": "vite preview",
    "test": "node --test --test-isolation=none"
  },
  "dependencies": {
    "electron-updater": "6.8.9",
    "ssh2": "1.17.0"
  },
  "devDependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.25.12",
    "playwright": "^1.61.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.9.2",
    "vite": "6.4.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
